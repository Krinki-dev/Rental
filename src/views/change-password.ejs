<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head', { title: 'Change password' }) %></head>
<body>
  <div class="login-wrap">
    <div class="login-card">
      <h1>Set a new password</h1>
      <p class="sub">For security, please set your own password before continuing.</p>

      <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

      <form method="POST" action="/change-password">
        <label for="new_password">New password</label>
        <input id="new_password" name="new_password" type="password" required minlength="4" autofocus>

        <label for="confirm_password">Confirm new password</label>
        <input id="confirm_password" name="confirm_password" type="password" required minlength="4">

        <div class="btn-row">
          <button class="btn" type="submit" style="width:100%">Save & continue</button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>

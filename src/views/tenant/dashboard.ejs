<%- include('../partials/head', { title: 'My Flat' }) %>
<%- include('../partials/tenant-nav', { active: 'dashboard' }) %>

<section class="container">
  <div class="page-header">
    <div>
      <h1>Flat <%= tenant.flat_code %></h1>
      <p><%= tenant.society_name %> <% if (tenant.tower || tenant.floor || tenant.unit) { %>• Tower <%= tenant.tower || '-' %>, Floor <%= tenant.floor || '-' %>, Unit <%= tenant.unit || '-' %><% } %></p>
    </div>
  </div>

  <div class="stats-grid">
    <article class="stat-card">
      <span class="label">Monthly rent</span>
      <strong><%= formatINR(tenant.rent_amount || 0) %></strong>
    </article>
    <article class="stat-card">
      <span class="label">This month payment</span>
      <strong><%= thisMonthPayment ? formatINR(thisMonthPayment.amount_paid || 0) : formatINR(0) %></strong>
      <small><%= thisMonthPayment ? thisMonthPayment.status : 'Not submitted yet' %></small>
    </article>
    <article class="stat-card">
      <span class="label">Security balance</span>
      <strong><%= formatINR((securitySummary && securitySummary.balance) || 0) %></strong>
      <small>Collected: <%= formatINR((securitySummary && securitySummary.collected) || 0) %></small>
    </article>
    <article class="stat-card">
      <span class="label">GST status</span>
      <strong><%= tenant.gst_registered ? 'Registered' : 'Not Registered' %></strong>
      <small><%= tenant.gstin || 'GST not added' %></small>
    </article>
  </div>

  <div class="layout-grid">
    <section class="card">
      <div class="section-head">
        <h2>Dues and balances</h2>
        <a href="/tenant/payments" class="link-btn">Go to payments</a>
      </div>
      <% if (!dues || !dues.length) { %>
        <p class="muted">No dues are visible right now.</p>
      <% } else { %>
        <div class="list-wrap">
          <% dues.slice(0, 10).forEach((d) => { %>
            <div class="list-item split-row">
              <div>
                <strong><%= d.custom_label || d.due_type %></strong>
                <small><%= d.for_month || d.due_date || 'No due date' %></small>
              </div>
              <div class="right-align">
                <strong><%= formatINR(d.due_amount || 0) %></strong>
                <small class="status <%= d.status %>"><%= d.status %></small>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </section>

    <section class="card">
      <div class="section-head">
        <h2>Quick actions</h2>
      </div>
      <div class="quick-actions">
        <a class="action-tile" href="/tenant/payments">Submit payment details</a>
        <a class="action-tile" href="/tenant/maintenance">Raise maintenance request</a>
        <a class="action-tile" href="/tenant/agreement">View agreement</a>
      </div>
    </section>
  </div>

  <div class="layout-grid second-row">
    <section class="card">
      <div class="section-head">
        <h2>Electricity ledger</h2>
      </div>
      <% if (!electricityRows || !electricityRows.length) { %>
        <p class="muted">No electricity records available yet.</p>
      <% } else { %>
        <div class="list-wrap">
          <% electricityRows.forEach((row) => { %>
            <div class="list-item split-row">
              <div>
                <strong><%= row.for_month %></strong>
                <small><%= row.opening_reading %> to <%= row.closing_reading %> units</small>
              </div>
              <div class="right-align">
                <strong><%= formatINR(row.amount || 0) %></strong>
                <small>Paid: <%= formatINR(row.paid_amount || 0) %></small>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </section>

    <section class="card">
      <div class="section-head">
        <h2>Water ledger</h2>
      </div>
      <% if (!waterRows || !waterRows.length) { %>
        <p class="muted">No water records available yet.</p>
      <% } else { %>
        <div class="list-wrap">
          <% waterRows.forEach((row) => { %>
            <div class="list-item split-row">
              <div>
                <strong><%= row.for_month %></strong>
                <small>Due: <%= row.due_date || 'Not set' %></small>
              </div>
              <div class="right-align">
                <strong><%= formatINR(row.bill_amount || 0) %></strong>
                <small>Paid: <%= formatINR(row.paid_amount || 0) %></small>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </section>
  </div>
</section>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 24px 16px 40px; }
  .page-header { margin-bottom: 20px; }
  .page-header h1 { margin: 0 0 8px; }
  .page-header p { margin: 0; color: #6b7280; }
  .stats-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; margin-bottom: 20px; }
  .stat-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 14px; padding: 16px; display: flex; flex-direction: column; gap: 8px; }
  .stat-card strong { font-size: 1.4rem; }
  .label, .stat-card small, .muted { color: #6b7280; }
  .layout-grid { display: grid; grid-template-columns: 1.3fr .9fr; gap: 16px; margin-bottom: 20px; }
  .second-row { grid-template-columns: 1fr 1fr; }
  .card { background: #fff; border: 1px solid #e5e7eb; border-radius: 14px; padding: 16px; }
  .section-head { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-bottom: 12px; }
  .section-head h2 { margin: 0; font-size: 1.1rem; }
  .link-btn { color: #2563eb; text-decoration: none; font-weight: 600; }
  .quick-actions { display: grid; gap: 10px; }
  .action-tile { display: block; text-decoration: none; color: #111827; border: 1px solid #e5e7eb; border-radius: 12px; padding: 12px 14px; background: #fafafa; font-weight: 600; }
  .list-wrap { display: grid; gap: 10px; }
  .list-item { border: 1px solid #e5e7eb; border-radius: 12px; padding: 12px; background: #fafafa; }
  .split-row { display: flex; justify-content: space-between; gap: 12px; align-items: center; }
  .list-item small { display: block; margin-top: 4px; color: #6b7280; }
  .right-align { text-align: right; }
  .status { text-transform: capitalize; }
  .status.overdue { color: #b91c1c; }
  .status.current { color: #92400e; }
  .status.upcoming { color: #1d4ed8; }
  .status.paid { color: #166534; }
  @media (max-width: 1000px) {
    .stats-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .layout-grid, .second-row { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .stats-grid { grid-template-columns: 1fr; }
  }
</style>
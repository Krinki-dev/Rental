<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head', { title: 'Edit Payment' }) %></head>
<body>
<%- include('../partials/tenant-nav', { active: 'payments' }) %>
<div class="shell">
  <div class="page-head">
    <h1>Edit Payment</h1>
    <p>Update your payment details for <%= payment.for_month %></p>
  </div>

  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

  <div class="card" style="max-width:700px">
    <form method="POST" action="/tenant/payments/<%= payment.id %>/edit" class="payment-form" onsubmit="disableSubmit(this)">
      <div class="grid-2">
        <div>
          <label>For month</label>
          <input type="month" name="for_month" value="<%= payment.for_month %>" required>
        </div>
        <div>
          <label>Payment date</label>
          <input type="date" name="payment_date" value="<%= payment.payment_date ? new Date(payment.payment_date).toISOString().slice(0,10) : '' %>" required>
        </div>
        <div>
          <label>Total paid amount</label>
          <input type="number" step="0.01" name="amount_paid" value="<%= payment.amount_paid || 0 %>" required>
        </div>
        <div>
          <label>Payment mode</label>
          <select name="mode" required>
            <option value="UPI" <%= payment.mode === 'UPI' ? 'selected' : '' %>>UPI</option>
            <option value="Bank Transfer" <%= payment.mode === 'Bank Transfer' ? 'selected' : '' %>>Bank Transfer</option>
            <option value="Cash" <%= payment.mode === 'Cash' ? 'selected' : '' %>>Cash</option>
            <option value="Cheque" <%= payment.mode === 'Cheque' ? 'selected' : '' %>>Cheque</option>
            <option value="Other" <%= payment.mode === 'Other' ? 'selected' : '' %>>Other</option>
          </select>
        </div>
        <div>
          <label>Reference / UTR No.</label>
          <input type="text" name="reference_no" value="<%= payment.reference_no || '' %>" placeholder="Transaction reference number">
        </div>
        <div>
          <label>Notes</label>
          <input type="text" name="notes" value="<%= payment.notes || '' %>" placeholder="Optional note for admin">
        </div>
      </div>

      <div class="line-items-box">
        <div class="line-items-head">
          <h3>Payment breakup</h3>
          <button type="button" class="btn btn-secondary btn-sm" onclick="addLineItem()">Add line</button>
        </div>
        <div id="line-items">
          <% if (items && items.length) { %>
            <% items.forEach((item) => { %>
              <div class="line-item-row">
                <select name="item_purpose">
                  <option value="rent" <%= item.purpose === 'rent' ? 'selected' : '' %>>Rent</option>
                  <option value="security_deposit" <%= item.purpose === 'security_deposit' ? 'selected' : '' %>>Security Deposit</option>
                  <option value="electricity" <%= item.purpose === 'electricity' ? 'selected' : '' %>>Electricity</option>
                  <option value="water" <%= item.purpose === 'water' ? 'selected' : '' %>>Water</option>
                  <option value="maintenance" <%= item.purpose === 'maintenance' ? 'selected' : '' %>>Maintenance</option>
                  <option value="penalty" <%= item.purpose === 'penalty' ? 'selected' : '' %>>Penalty</option>
                  <option value="parking" <%= item.purpose === 'parking' ? 'selected' : '' %>>Parking</option>
                  <option value="club_charges" <%= item.purpose === 'club_charges' ? 'selected' : '' %>>Club Charges</option>
                  <option value="gst" <%= item.purpose === 'gst' ? 'selected' : '' %>>GST</option>
                  <option value="other" <%= item.purpose === 'other' ? 'selected' : '' %>>Other</option>
                </select>
                <input type="text" name="item_label" value="<%= item.custom_label || '' %>" placeholder="Custom label if Other">
                <input type="number" step="0.01" name="item_amount" value="<%= item.amount %>" required>
                <button type="button" class="btn btn-secondary btn-sm" onclick="removeLine(this)">Remove</button>
              </div>
            <% }) %>
          <% } else { %>
            <div class="line-item-row">
              <select name="item_purpose">
                <option value="rent">Rent</option>
                <option value="security_deposit">Security Deposit</option>
                <option value="electricity">Electricity</option>
                <option value="water">Water</option>
                <option value="maintenance">Maintenance</option>
                <option value="penalty">Penalty</option>
                <option value="parking">Parking</option>
                <option value="club_charges">Club Charges</option>
                <option value="gst">GST</option>
                <option value="other">Other</option>
              </select>
              <input type="text" name="item_label" placeholder="Custom label if Other">
              <input type="number" step="0.01" name="item_amount" value="<%= payment.amount_paid || 0 %>" required>
              <button type="button" class="btn btn-secondary btn-sm" onclick="removeLine(this)">Remove</button>
            </div>
          <% } %>
        </div>
      </div>

      <button type="submit" class="btn btn-primary" id="submitBtn">Update Payment</button>
    </form>
  </div>
</div>

<script>
  function addLineItem() {
    const wrap = document.getElementById('line-items');
    const row = document.createElement('div');
    row.className = 'line-item-row';
    row.innerHTML = `
      <select name="item_purpose">
        <option value="rent">Rent</option>
        <option value="security_deposit">Security Deposit</option>
        <option value="electricity">Electricity</option>
        <option value="water">Water</option>
        <option value="maintenance">Maintenance</option>
        <option value="penalty">Penalty</option>
        <option value="parking">Parking</option>
        <option value="club_charges">Club Charges</option>
        <option value="gst">GST</option>
        <option value="other">Other</option>
      </select>
      <input type="text" name="item_label" placeholder="Custom label if Other">
      <input type="number" step="0.01" name="item_amount" placeholder="Amount" required>
      <button type="button" class="btn btn-secondary btn-sm" onclick="removeLine(this)">Remove</button>
    `;
    wrap.appendChild(row);
  }

  function removeLine(button) {
    const rows = document.querySelectorAll('.line-item-row');
    if (rows.length === 1) return;
    button.closest('.line-item-row').remove();
  }

  function disableSubmit(form) {
    const btn = document.getElementById('submitBtn');
    if (!btn) return true;
    btn.disabled = true;
    btn.innerText = 'Updating...';
    return true;
  }
</script>

<style>
  .shell { max-width: 800px; margin: 0 auto; padding: 24px 16px 40px; }
  .page-head { margin-bottom: 20px; }
  .page-head h1 { margin: 0 0 8px; }
  .card { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 16px; }
  .payment-form label { display: block; font-size: 12px; font-weight: 700; color: #4b5563; margin-bottom: 6px; }
  .payment-form input, .payment-form select { width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 8px; font: inherit; }
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px; }
  .line-items-box { border: 1px solid #e5e7eb; border-radius: 12px; padding: 12px; background: #fafafa; margin-bottom: 16px; }
  .line-items-head { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-bottom: 12px; }
  .line-items-head h3 { margin: 0; font-size: 1rem; }
  .line-item-row { display: grid; grid-template-columns: 1.2fr 1fr 160px 100px; gap: 10px; margin-bottom: 10px; }
  .btn { border: 0; border-radius: 8px; padding: 10px 14px; cursor: pointer; font-weight: 700; }
  .btn-primary { background: #111827; color: #fff; }
  .btn-secondary { background: #f3f4f6; color: #111827; }
  .btn-sm { font-size: 13px; padding: 8px 10px; }
  @media (max-width: 700px) {
    .grid-2, .line-item-row { grid-template-columns: 1fr; }
  }
</style>
</body>
</html>
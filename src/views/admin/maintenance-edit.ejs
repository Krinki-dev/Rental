<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head', { title: 'Edit Maintenance Request' }) %></head>
<body>
<%- include('../partials/admin-nav', { active: 'maintenance' }) %>
<div class="shell">
  <div class="page-head">
    <h1>Edit Maintenance Request</h1>
    <p>Flat <%= request.flat_code %> - <%= request.full_name %></p>
  </div>

  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

  <div class="card" style="max-width:560px">
    <form method="POST" action="/admin/maintenance/<%= request.id %>/edit">
      <label for="issue_type">Issue Type</label>
      <input id="issue_type" name="issue_type" required value="<%= request.issue_type %>" placeholder="e.g. Tap leaking, fan not working">

      <label for="description">Description</label>
      <textarea id="description" name="description" rows="3"><%= request.description || '' %></textarea>

      <div class="field-row">
        <div>
          <label for="priority">Priority</label>
          <select id="priority" name="priority">
            <option value="low" <%= request.priority === 'low' ? 'selected' : '' %>>Low</option>
            <option value="medium" <%= request.priority === 'medium' ? 'selected' : '' %>>Medium</option>
            <option value="high" <%= request.priority === 'high' ? 'selected' : '' %>>High</option>
          </select>
        </div>
        <div>
          <label for="status">Status</label>
          <select id="status" name="status">
            <option value="open" <%= request.status === 'open' ? 'selected' : '' %>>Open</option>
            <option value="in_progress" <%= request.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
            <option value="resolved" <%= request.status === 'resolved' ? 'selected' : '' %>>Resolved</option>
          </select>
        </div>
      </div>

      <div class="btn-row">
        <button class="btn" type="submit">Update request</button>
        <a class="btn btn-secondary" href="/admin/maintenance">Cancel</a>
      </div>
    </form>

    <form method="POST" action="/admin/maintenance/<%= request.id %>/delete" style="margin-top:16px;" onsubmit="return confirm('Delete this maintenance request permanently?');">
      <button type="submit" class="btn btn-danger">Delete Request</button>
    </form>
  </div>
</div>
</body>
</html>
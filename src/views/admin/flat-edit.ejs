<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head', { title: 'Edit Flat' }) %></head>
<body>
<%- include('../partials/admin-nav', { active: 'flats' }) %>
<div class="shell">
  <div class="page-head">
    <h1>Edit Flat</h1>
    <p>Update flat details for <%= flat.flat_code %></p>
  </div>

  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

  <div class="card" style="max-width:560px">
    <form method="POST" action="/admin/flats/<%= flat.id %>/edit">
      <label for="flat_code">Flat code</label>
      <input id="flat_code" name="flat_code" required placeholder="e.g. E-1001" value="<%= flat.flat_code %>">

      <div class="field-row">
        <div>
          <label for="tower">Tower</label>
          <input id="tower" name="tower" placeholder="E" value="<%= flat.tower || '' %>">
        </div>
        <div>
          <label for="floor">Floor</label>
          <input id="floor" name="floor" placeholder="10" value="<%= flat.floor || '' %>">
        </div>
        <div>
          <label for="unit">Unit</label>
          <input id="unit" name="unit" placeholder="01" value="<%= flat.unit || '' %>">
        </div>
      </div>

      <label for="rent_amount">Monthly rent (₹)</label>
      <input id="rent_amount" name="rent_amount" type="number" min="0" step="1" required placeholder="12000" value="<%= flat.rent_amount %>">

      <div class="btn-row">
        <button class="btn" type="submit">Update flat</button>
        <a class="btn btn-secondary" href="/admin/flats">Cancel</a>
      </div>
    </form>
  </div>
</div>
</body>
</html>
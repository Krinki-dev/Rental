<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head', { title: 'Payments' }) %></head>
<body>
<%- include('../partials/admin-nav', { active: 'payments' }) %>
<div class="shell">
  <div class="page-head">
    <h1>Payments</h1>
    <p>Confirm a payment to auto-calculate late fees and email the receipt.</p>
  </div>

  <div class="card table-wrap">
    <table>
      <thead>
        <tr><th>Flat</th><th>Tenant</th><th>Month</th><th class="num">Paid</th><th>Reference</th><th>Status</th><th></th></tr>
      </thead>
      <tbody>
        <% payments.forEach(p => { %>
        <tr>
          <td class="mono"><%= p.flat_code %></td>
          <td><%= p.full_name %></td>
          <td><%= p.for_month %></td>
          <td class="num mono"><%= p.amount_paid ? formatINR(p.amount_paid) : '-' %></td>
          <td class="mono"><%= p.reference_no || '-' %></td>
          <td>
            <% if (p.status === 'confirmed') { %><span class="badge badge-success">Confirmed</span>
            <% } else { %><span class="badge badge-warning">Pending</span><% } %>
          </td>
          <td>
            <% if (p.status === 'pending') { %>
            <form method="POST" action="/admin/payments/<%= p.id %>/confirm">
              <button class="btn btn-sm" type="submit">Confirm & email receipt</button>
            </form>
            <% } %>
          </td>
        </tr>
        <% }) %>
        <% if (payments.length === 0) { %>
          <tr><td colspan="7" class="empty">No payments yet.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
</body>
</html>

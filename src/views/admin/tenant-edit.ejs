<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head', { title: 'Edit Tenant' }) %></head>
<body>
<%- include('../partials/admin-nav', { active: 'flats' }) %>
<div class="shell">
  <div class="page-head">
    <h1>Edit Tenant</h1>
    <p>Update tenant details</p>
  </div>

  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

  <div class="card" style="max-width:700px">
    <form method="POST" action="/admin/flats/<%= flatId %>/tenant/<%= tenant.id %>/edit">
      <div class="field-row">
        <div>
          <label for="full_name">Full Name *</label>
          <input id="full_name" name="full_name" required value="<%= tenant.full_name %>">
        </div>
        <div>
          <label for="father_husband_name">Father/Husband Name</label>
          <input id="father_husband_name" name="father_husband_name" value="<%= tenant.father_husband_name || '' %>">
        </div>
      </div>

      <div class="field-row">
        <div>
          <label for="phone">Phone *</label>
          <input id="phone" name="phone" required value="<%= tenant.phone %>">
        </div>
        <div>
          <label for="alt_phone">Alt Phone</label>
          <input id="alt_phone" name="alt_phone" value="<%= tenant.alt_phone || '' %>">
        </div>
      </div>

      <div class="field-row">
        <div>
          <label for="email">Email</label>
          <input id="email" name="email" type="email" value="<%= tenant.email || '' %>">
        </div>
        <div>
          <label for="pan_number">PAN Number</label>
          <input id="pan_number" name="pan_number" placeholder="ABCDE1234F" value="<%= tenant.pan_number || '' %>">
        </div>
      </div>

      <div class="field-row">
        <div>
          <label for="aadhaar_number">Aadhaar Number</label>
          <input id="aadhaar_number" name="aadhaar_number" placeholder="XXXX-XXXX-XXXX" value="<%= tenant.aadhaar_number || '' %>">
        </div>
        <div>
          <label for="gstin">GSTIN</label>
          <input id="gstin" name="gstin" placeholder="27AABCT1234R1ZX" value="<%= tenant.gstin || '' %>">
        </div>
      </div>

      <label for="permanent_address">Permanent Address</label>
      <textarea id="permanent_address" name="permanent_address" rows="2"><%= tenant.permanent_address || '' %></textarea>

      <div class="field-row">
        <div>
          <label for="agreement_start">Agreement Start</label>
          <input id="agreement_start" name="agreement_start" type="date" value="<%= tenant.agreement_start || '' %>">
        </div>
        <div>
          <label for="agreement_end">Agreement End</label>
          <input id="agreement_end" name="agreement_end" type="date" value="<%= tenant.agreement_end || '' %>">
        </div>
      </div>

      <div class="field-row">
        <div>
          <label for="move_in_date">Move-in Date</label>
          <input id="move_in_date" name="move_in_date" type="date" value="<%= tenant.move_in_date || '' %>">
        </div>
        <div>
          <label for="security_deposit">Security Deposit (₹)</label>
          <input id="security_deposit" name="security_deposit" type="number" step="0.01" value="<%= tenant.security_deposit || 0 %>">
        </div>
      </div>

      <div class="field-row">
        <div>
          <label for="gst_registered">GST Registered</label>
          <select id="gst_registered" name="gst_registered">
            <option value="0" <%= !tenant.gst_registered ? 'selected' : '' %>>No</option>
            <option value="1" <%= tenant.gst_registered ? 'selected' : '' %>>Yes</option>
          </select>
        </div>
        <div>
          <label for="lifecycle_status">Status</label>
          <select id="lifecycle_status" name="lifecycle_status">
            <option value="draft" <%= tenant.lifecycle_status === 'draft' ? 'selected' : '' %>>Draft</option>
            <option value="approved" <%= tenant.lifecycle_status === 'approved' ? 'selected' : '' %>>Approved</option>
            <option value="move_in_scheduled" <%= tenant.lifecycle_status === 'move_in_scheduled' ? 'selected' : '' %>>Move-in Scheduled</option>
            <option value="move_in_confirmed" <%= tenant.lifecycle_status === 'move_in_confirmed' ? 'selected' : '' %>>Move-in Confirmed</option>
            <option value="active" <%= tenant.lifecycle_status === 'active' ? 'selected' : '' %>>Active</option>
            <option value="move_out_initiated" <%= tenant.lifecycle_status === 'move_out_initiated' ? 'selected' : '' %>>Move-out Initiated</option>
            <option value="vacated" <%= tenant.lifecycle_status === 'vacated' ? 'selected' : '' %>>Vacated</option>
          </select>
        </div>
      </div>

      <div class="field-row">
        <div>
          <label for="is_active">Active</label>
          <select id="is_active" name="is_active">
            <option value="1" <%= tenant.is_active ? 'selected' : '' %>>Yes</option>
            <option value="0" <%= !tenant.is_active ? 'selected' : '' %>>No</option>
          </select>
        </div>
      </div>

      <div class="btn-row">
        <button class="btn" type="submit">Update tenant</button>
        <a class="btn btn-secondary" href="/admin/flats/<%= flatId %>">Cancel</a>
      </div>
    </form>
  </div>
</div>
</body>
</html>
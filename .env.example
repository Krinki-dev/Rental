# ============================================
# RENTAL MANAGEMENT APP - ENVIRONMENT SETTINGS
# Copy this file to ".env" and fill in real values.
# Never commit the real ".env" file anywhere.
# ============================================

# --- Server ---
PORT=3000
APP_BASE_URL=https://yourapp.up.railway.app
NODE_ENV=production

# --- Database (Railway MySQL gives you this connection string automatically) ---
DATABASE_URL=mysql://user:password@host:port/dbname

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your-16-digit-gmail-app-password
SMTP_FROM_NAME=Pro Caryingway Enterprise

# --- First admin login (change the password immediately after first login) ---
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change-this-immediately

# --- Security ---
JWT_SECRET=replace-with-a-long-random-string

# --- Company / legal details (used on the agreement print-out & receipts) ---
COMPANY_NAME=PRO CARYINGWAY ENTERPRISE PRIVATE LIMITED
COMPANY_GSTIN=06AANCP9466H1ZS
COMPANY_REGISTERED_ADDRESS=Ground Floor, Jhajjar Road, Gudha, Jhajjar, Haryana - 124103

# --- Communication details (shown to tenants - portal footer, "contact us") ---
COMPANY_OFFICE_ADDRESS=
COMPANY_CONTACT_NUMBER=+91XXXXXXXXXX
COMPANY_EMAIL=
COMPANY_WHATSAPP_LINK=https://wa.me/91XXXXXXXXXX
REPRESENTATIVE_NAME=

# --- Payment details (shown to tenants on their "Pay rent" page) ---
# Bank transfer
BANK_ACCOUNT_NAME=
BANK_ACCOUNT_NUMBER=
BANK_IFSC=
BANK_NAME=
BANK_BRANCH=
# UPI - the QR code on the tenant payment page is generated automatically
# from these two values, with the exact rent amount filled in. No separate
# barcode image needs to be uploaded anywhere.
UPI_ID=yourname@upi
UPI_PAYEE_NAME=Pro Caryingway Enterprise

# --- Documents (v1 = plain Google Drive links only, no API credentials needed) ---
GDRIVE_ROOT_FOLDER_URL=https://drive.google.com/your-main-folder
